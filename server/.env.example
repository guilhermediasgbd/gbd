# Copie este arquivo para .env e preencha os valores reais
# NUNCA commite o .env no GitHub

# Obrigatorio - gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=troque-por-uma-string-longa-e-aleatoria

# Railway define PORT automaticamente - nao precisa mudar
PORT=3000

# Caminho do arquivo de dados - no Railway aponta para o volume persistente
DATA_FILE=/data/crm-data.json

# Dominio do frontend no Railway (ex: https://gbd-crm.up.railway.app)
ALLOWED_ORIGINS=https://seuapp.up.railway.app

# Google Drive (opcional - deixe vazio se nao usar)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
